# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eduquiz
DB_USERNAME=eduquiz
DB_PASSWORD=eduquiz

# ── Mail (Gmail App Password) ──
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ── JWT (generate: python -c "import secrets; print(secrets.token_urlsafe(48))") ──
JWT_SECRET=CHANGE_ME_TO_RANDOM_BASE64_STRING

# ── API Key (generate: python -c "import secrets; print(secrets.token_urlsafe(32))") ──
API_KEY=CHANGE_ME_TO_RANDOM_STRING

# ── Frontend ──
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
